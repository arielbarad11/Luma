<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fitsSystemWindows="false"
    android:layoutDirection="rtl"
    tools:context=".screens.MainActivity">

    <!-- רקע עליון עם גרדיאנט -->
    <View
        android:id="@+id/topBackground"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="#1A237E"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guideline - קו דמיוני שמונע מהטקסט לעלות על השעה והסוללה -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/statusBarGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="40dp" />

    <!-- אייקון קישוט עליון -->
    <TextView
        android:id="@+id/decorIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="✨"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/statusBarGuideline" />

    <TextView
        android:id="@+id/welcomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:elevation="4dp"
        android:fontFamily="@font/font_suezone_regular"
        android:text="תפריט ראשי"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/decorIcon" />

    <TextView
        android:id="@+id/helloUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:elevation="4dp"
        android:fontFamily="@font/font_suezone_regular"
        android:text="טוען..."
        android:textColor="#E0F2FE"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/welcomeTitle" />

    <!-- ScrollView עבור התוכן -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBackground">

        <!-- מיכל הכפתורים -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layoutDirection="rtl"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="32dp">

            <!-- כפתור אדמין (מוסתר כברירת מחדל) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btn_main_to_admin"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:backgroundTint="#DC2626"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="⚙️ חזרה לניהול המערכת"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:cornerRadius="14dp"
                        app:elevation="0dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/adminLine"
                android:layout_width="180dp"
                android:layout_height="2dp"
                android:layout_marginBottom="20dp"
                android:background="#E2E8F0"
                android:visibility="gone" />

            <!-- כרטיס מעקב מצב רוח -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="😊"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="מעקב מצב רוח"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="עקוב אחר הרגשות שלך לאורך זמן"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_main_to_MoodTracker"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="התחל מעקב ←"
                        android:textColor="#0369A1"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס סימולציית נשימה -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="🌬️"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="סימולציית נשימה"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="תרגילי נשימה להרגעה ורוגע"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_main_to_BreathingSimulation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="התחל תרגול ←"
                        android:textColor="#0891B2"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס מוסיקה מרגיעה -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="🎵"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="מוסיקה מרגיעה"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="האזן למוסיקה שתרגיע את הנפש"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_main_to_Music"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="נגן מוסיקה ←"
                        android:textColor="#7C3AED"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס רשימת פסיכולוגים -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="👨‍⚕️"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="רשימת פסיכולוגים"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="מצא את המטפל המתאים לך"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_main_to_PsychologistList"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="צפה ברשימה ←"
                        android:textColor="#059669"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס מטרות יומיות -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="🎯"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="מטרות יומיות"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="הגדר והשג את המטרות שלך"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_main_to_Goals"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="נהל מטרות ←"
                        android:textColor="#F59E0B"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס עדכון פרטי משתמש -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A237E"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="8dp"
                        android:text="👤"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/font_secularone_regular"
                        android:gravity="right"
                        android:text="עדכון פרטי משתמש"
                        android:textColor="@color/white"
                        android:textDirection="rtl"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"
                        android:text="עדכן את הפרופיל והגדרות שלך"
                        android:textColor="#E0F2FE"
                        android:textDirection="rtl"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/tv_main_UpdateUser"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/white"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="עדכן פרטים ←"
                        android:textColor="#DC2626"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- קו מפריד -->
            <View
                android:layout_width="200dp"
                android:layout_height="2dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="#E2E8F0" />

            <!-- כפתור התנתקות -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:gravity="center"
                    android:layoutDirection="ltr"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="🚪"
                        android:textSize="24sp" />

                    <Button
                        android:id="@+id/btn_main_to_exit"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:backgroundTint="#6B7280"
                        android:fontFamily="@font/font_secularone_regular"
                        android:text="התנתק מהמערכת"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>