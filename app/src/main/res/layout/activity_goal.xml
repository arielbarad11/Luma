<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layoutDirection="rtl"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/font_secularone_regular"
            android:layoutDirection="rtl"
            android:text="הוסף מטרה חדשה"
            android:textColor="#1A237E"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:layoutDirection="rtl"
            android:text="הגדר תזכורת יומית להשגת היעדים שלך"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <!-- Title Input Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layoutDirection="rtl"
                    android:text="שם המטרה"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="לדוגמה: אימון בוקר, קריאה"
                    app:boxBackgroundColor="#F1F5F9"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxStrokeColor="#3B82F6"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#64748B"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:startIconTint="#3B82F6">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="right"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="#1E293B"
                        android:textDirection="rtl"
                        android:textSize="16sp" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Time Picker Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layoutDirection="rtl"
                    android:text="זמן התזכורת"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TimePicker
                    android:id="@+id/timePicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F8FAFC"
                    android:layoutDirection="ltr"
                    android:padding="12dp"
                    android:timePickerMode="spinner" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Days Selection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/font_secularone_regular"
                    android:layoutDirection="rtl"
                    android:text="בחר ימים"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:layoutDirection="rtl"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/checkSun"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="ראשון"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/checkMon"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="שני"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/checkTue"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="שלישי"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:layoutDirection="rtl"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/checkWed"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="רביעי"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/checkThu"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="חמישי"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                    <CheckBox
                        android:id="@+id/checkFri"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="שישי"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layoutDirection="rtl"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/checkSat"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/btn_default"
                        android:backgroundTint="#EFF6FF"
                        android:buttonTint="#3B82F6"
                        android:gravity="center"
                        android:layoutDirection="rtl"
                        android:text="שבת"
                        android:textColor="#1E293B"
                        android:textSize="14sp" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3B82F6"
            android:fontFamily="@font/font_secularone_regular"
            android:layoutDirection="rtl"
            android:paddingVertical="14dp"
            android:text="שמור מטרה"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:elevation="4dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:layoutDirection="rtl"
            android:text="תזכורת: המערכת תשלח לך התראות בזמנים שהגדרת"
            android:textColor="#64748B"
            android:textSize="12sp" />

        <!-- Existing Goals Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="rtl"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="@font/font_secularone_regular"
                    android:text="התראות קיימות"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/goalsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvEmptyGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="אין התראות עדיין"
                    android:textColor="#94A3B8"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>