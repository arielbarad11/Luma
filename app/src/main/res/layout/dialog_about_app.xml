<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="למה הקמנו את Luma?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0984E3"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="בעקבות אירועי ה-7 באוקטובר, הבנו שהצורך במענה מיידי, נגיש ובעברית להתמודדות עם חרדה הוא קריטי מתמיד. Luma נולדה כדי להעניק 'עזרה ראשונה' רגשית וכלים פרקטיים לבניית חוסן נפשי בשגרה ובחירום."
                    android:lineSpacingExtra="4dp"
                    android:textSize="15sp"
                    android:textColor="#2D3436"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="מה האפליקציה מציעה?"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#00B894"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• תרגול נשימה ויזואלי להרגעת המערכת.\n• יומן רגשות דיגיטלי למעקב אישי.\n• גרף התקדמות שבועי המציג את התהליך שלך.\n• 'בנק פתרונות' אישי למצבי חירום.\n• מוזיקה מרגיעה להפחתת מתחים."
                    android:lineSpacingExtra="6dp"
                    android:textSize="15sp"
                    android:textColor="#2D3436"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#FFEAA7"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_dialog_info"
                    app:tint="#D6A000"
                    android:layout_marginLeft="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="חשוב לדעת: Luma היא כלי עזר תומך ואינה מהווה תחליף לטיפול מקצועי, רפואי או פסיכולוגי."
                    android:textSize="13sp"
                    android:textColor="#7A5D00"
                    android:textStyle="italic"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="פותח באהבה ובשליחות עבור הקהילה."
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:textColor="#B2BEC3"
            android:paddingBottom="5dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="כל הזכויות שמורות לאריאל שמידט ברד"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="5dp"
            android:textColor="#B2BEC3"
            android:paddingBottom="5dp"/>



    </LinearLayout>
</ScrollView>